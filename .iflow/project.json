{
    "project": {
        "name": "iflow-skills",
        "description": "iFlow CLI 技能集合，为 iFlow CLI 提供可重用的专业技能扩展",
        "version": "1.0.0",
        "repository": "https://github.com/lryouyu/iflow-skills.git"
    },
    "structure": {
        "root": {
            "files": [
                {
                    "name": "README.md",
                    "description": "项目说明文档"
                },
                {
                    "name": "AGENTS.md",
                    "description": "项目上下文文档，包含项目概述、核心技能说明、技术栈参考、开发工作流程等"
                }
            ],
            "directories": [
                {
                    "name": "skills",
                    "description": "技能定义目录，包含所有技能的详细定义和参考文档"
                },
                {
                    "name": "commands",
                    "description": "命令配置目录，包含为 iFlow CLI 生成的命令文件"
                },
                {
                    "name": "iflow",
                    "description": "iFlow 配置目录，存放项目相关的 JSON 配置文件"
                }
            ]
        },
        "skills": {
            "description": "技能定义目录",
            "items": [
                {
                    "name": "command-creator",
                    "description": "命令创建器技能，帮助用户创建自定义 iFlow CLI 命令",
                    "files": [
                        "SKILL.md"
                    ]
                },
                {
                    "name": "frontend-code-review",
                    "description": "前端代码审查技能，针对 LVM 项目的前端代码进行系统性审查",
                    "files": [
                        "SKILL.md",
                        "references/lvm-standards.md",
                        "references/react-best-practices.md"
                    ]
                },
                {
                    "name": "spec-mode",
                    "description": "规范优先开发模式，系统化的开发工作流，强调先规划后执行",
                    "files": [
                        "SKILL.md",
                        "README.md",
                        "examples/shopping-cart/requirements.md",
                        "examples/shopping-cart/design.md",
                        "examples/shopping-cart/tasks.md"
                    ]
                }
            ]
        },
        "commands": {
            "description": "命令配置目录，包含为 iFlow CLI 生成的命令文件",
            "format": "TOML",
            "items": [
                {
                    "name": "command-creator.toml",
                    "description": "命令创建器命令配置"
                },
                {
                    "name": "frontend-code-review.toml",
                    "description": "前端代码审查命令配置"
                },
                {
                    "name": "spec-mode.toml",
                    "description": "规范优先开发模式命令配置"
                }
            ]
        }
    },
    "skills_detail": [
        {
            "id": "command-creator",
            "name": "Command Creator",
            "name_zh": "命令创建器",
            "description": "帮助用户创建自定义 iFlow CLI 命令，支持 TOML 和 Markdown 格式配置，提供全局和项目级命令安装",
            "use_cases": [
                "创建新的自定义命令",
                "配置命令定义文件",
                "管理已安装的命令"
            ],
            "output_locations": {
                "global": "~/.iflow/commands/",
                "project": "{project}/.iflow/commands/"
            }
        },
        {
            "id": "frontend-code-review",
            "name": "Frontend Code Review",
            "name_zh": "前端代码审查",
            "description": "LVM 项目前端代码审查技能，基于 git diff 分析进行 TypeScript/React 代码审查，检查代码质量、类型安全、性能优化和最佳实践合规性",
            "tech_stack": [
                "Tauri",
                "React 19.1.0",
                "TypeScript",
                "Ant Design 6.3.0",
                "Redux Toolkit 2.11.2",
                "React Router DOM 7.13.0",
                "i18next 25.8.13"
            ],
            "review_scope": [
                "React 组件（.tsx, .jsx）",
                "TypeScript/JavaScript 文件（.ts, .js）",
                "自定义 Hooks",
                "Redux Slices",
                "路由配置",
                "API 调用层"
            ],
            "review_standards": [
                "代码风格（Prettier + ESLint）",
                "TypeScript 类型安全",
                "React 最佳实践",
                "Tauri API 调用规范",
                "状态管理规范",
                "性能优化",
                "安全性检查"
            ]
        },
        {
            "id": "spec-mode",
            "name": "Spec Mode",
            "name_zh": "规范优先开发模式",
            "description": "规范优先开发模式，系统化的开发工作流，自动生成规范文档（需求、设计、任务），强制执行先规划后编码的纪律",
            "trigger_conditions": [
                "用户提出新功能需求",
                "用户报告需要修复的 Bug",
                "任何需要编写代码的任务"
            ],
            "outputs": [
                ".iflow/specs/<feature-name>/requirements.md - 需求定义文档",
                ".iflow/specs/<feature-name>/design.md - 技术设计文档",
                ".iflow/specs/<feature-name>/tasks.md - 实现任务清单"
            ],
            "workflow": [
                "阶段 1：需求分析",
                "阶段 2：技术设计",
                "阶段 3：任务分解",
                "阶段 4：用户确认",
                "阶段 5：执行开发（可选）"
            ]
        }
    ],
    "tech_stack": {
        "frontend": {
            "framework": "React 19.1.0",
            "ui_library": "Ant Design 6.3.0",
            "state_management": "Redux Toolkit 2.11.2",
            "routing": "React Router DOM 7.13.0",
            "internationalization": "i18next 25.8.13",
            "desktop_framework": "Tauri",
            "build_tool": "Bun"
        },
        "code_quality": {
            "type_checking": "TypeScript",
            "formatting": "Prettier",
            "linting": "ESLint",
            "testing": "Vitest + React Testing Library (推荐)"
        },
        "file_naming_conventions": {
            "components": "PascalCase (例如: VersionTable.tsx)",
            "utilities": "camelCase (例如: store.ts)",
            "constants_enums": "PascalCase (例如: LangEnum)",
            "custom_hooks": "camelCase + use 前缀 (例如: useDownload.ts)",
            "type_definitions": "camelCase (例如: common.ts)"
        }
    },
    "common_commands": {
        "git": [
            {
                "command": "git diff HEAD",
                "description": "查看未暂存的更改"
            },
            {
                "command": "git diff --staged",
                "description": "查看已暂存的更改"
            },
            {
                "command": "git diff HEAD -- <file-path>",
                "description": "查看特定文件的更改"
            },
            {
                "command": "git diff HEAD~N HEAD",
                "description": "查看最近 N 次提交的更改"
            },
            {
                "command": "git diff main...HEAD",
                "description": "比较分支"
            }
        ],
        "code_quality": [
            {
                "command": "bun run lint",
                "description": "运行 ESLint 检查"
            },
            {
                "command": "bun run lint:fix",
                "description": "自动修复 ESLint 问题"
            },
            {
                "command": "bun run format",
                "description": "运行 Prettier 格式化"
            },
            {
                "command": "bun run build",
                "description": "TypeScript 类型检查"
            }
        ],
        "command_management": [
            {
                "command": "/commands online",
                "description": "列出在线命令库"
            },
            {
                "command": "/commands get <id>",
                "description": "查看命令详情"
            },
            {
                "command": "/commands add <id>",
                "description": "安装命令"
            },
            {
                "command": "/commands list",
                "description": "列出已安装命令"
            },
            {
                "command": "/commands remove <name>",
                "description": "删除命令"
            }
        ]
    },
    "conventional_commits": {
        "format": "<type>(<scope>): <subject>",
        "types": [
            {
                "type": "feat",
                "description": "新功能"
            },
            {
                "type": "fix",
                "description": "Bug 修复"
            },
            {
                "type": "refactor",
                "description": "重构（不改变功能）"
            },
            {
                "type": "perf",
                "description": "性能优化"
            },
            {
                "type": "style",
                "description": "代码风格改进"
            },
            {
                "type": "docs",
                "description": "文档更新"
            },
            {
                "type": "test",
                "description": "测试相关"
            },
            {
                "type": "chore",
                "description": "构建/CI 相关"
            },
            {
                "type": "build",
                "description": "构建系统或外部依赖变更"
            }
        ],
        "scopes": [
            "frontend",
            "rust",
            "i18n",
            "types",
            "api",
            "ui"
        ],
        "subject_rules": [
            "使用祈使语气（add 而非 added）",
            "首字母小写",
            "结尾不加句号",
            "限制在 50 字符以内"
        ]
    },
    "references": {
        "internal": [
            {
                "name": "AGENTS.md",
                "description": "项目上下文文档（本文件）"
            },
            {
                "name": "README.md",
                "description": "项目说明文档"
            },
            {
                "name": "LVM 代码标准",
                "path": "skills/frontend-code-review/references/lvm-standards.md",
                "description": "LVM 项目代码标准"
            },
            {
                "name": "React 最佳实践",
                "path": "skills/frontend-code-review/references/react-best-practices.md",
                "description": "React 开发最佳实践"
            }
        ],
        "external": [
            {
                "name": "React 官方文档",
                "url": "https://react.dev/"
            },
            {
                "name": "TypeScript 官方文档",
                "url": "https://www.typescriptlang.org/"
            },
            {
                "name": "Ant Design 文档",
                "url": "https://ant.design/"
            },
            {
                "name": "Redux Toolkit 文档",
                "url": "https://redux-toolkit.js.org/"
            },
            {
                "name": "Tauri 官方文档",
                "url": "https://tauri.app/"
            },
            {
                "name": "i18next 文档",
                "url": "https://www.i18next.com/"
            },
            {
                "name": "Conventional Commits",
                "url": "https://www.conventionalcommits.org/"
            }
        ]
    },
    "created_at": "2025-03-03",
    "last_updated": "2025-03-03"
}